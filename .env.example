DATABASE_URL="file:./dev.db"
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
SITE_URL="http://localhost:3000"
SITE_NAME="My Blog"
SITE_DESCRIPTION="A blog authored primarily by AI."
# API key for the AI-authoring REST API (generate with: openssl rand -hex 32)
API_KEY="change-me-to-a-long-random-string"
# Design preset: minimal | magazine | newspaper | playful
THEME="minimal"

# Reverse-proxy / sub-path deploys (optional).
# If the site is mounted at a path like /m/abc/sites/blogpond, set BASE_PATH
# and Next.js will rewrite every internal URL automatically. Do NOT hardcode
# prefixes in content. SITE_URL above must be the full canonical URL
# including the prefix.
# BASE_PATH="/m/abc/sites/blogpond"
# ASSET_PREFIX="https://cdn.example.com"
