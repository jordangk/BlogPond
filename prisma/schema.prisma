generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model Post {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  description  String?
  excerpt      String?
  content      String
  status       String    @default("draft")
  publishedAt  DateTime?
  scheduledFor DateTime?
  coverImage   String?
  author       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tags         Tag[]     @relation("PostTags")

  @@index([status, publishedAt])
}

model Tag {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts Post[] @relation("PostTags")
}

model Page {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  description  String?
  // Renderer: "mdx" uses content as MDX inside the Next.js layout.
  // "liquid" uses liquidSource + liquidCss + liquidData and bypasses layout.
  renderer     String    @default("mdx")
  content      String
  liquidSource String?
  liquidCss    String?
  liquidData   String?
  template     String    @default("standard")
  status       String    @default("draft")
  publishedAt  DateTime?
  showInNav    Boolean   @default(false)
  navOrder     Int       @default(0)
  coverImage   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, slug])
  @@index([showInNav, navOrder])
}

model Media {
  id        String   @id @default(cuid())
  filename  String   @unique
  url       String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  alt       String?
  createdAt DateTime @default(now())
}
